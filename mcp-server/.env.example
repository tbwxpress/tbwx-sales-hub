# TBWX Sales Hub MCP server — environment
#
# These are the SAME variable names the Next.js app uses (src/lib/db.ts), so a
# single shared .env works for both. Copy this file to .env and fill in real
# values (do NOT commit the real .env).

# libsql / Turso database URL.
#  - Production: the Turso URL, e.g. libsql://your-db-name.turso.io
#  - Local dev:  a file URL, e.g. file:./data/inbox.db
# If unset, the server falls back to file:data/inbox.db (same default as the app).
TURSO_DATABASE_URL=

# Turso auth token. Required for a remote libsql:// URL; leave blank for a
# local file: database.
TURSO_AUTH_TOKEN=

# Optional. Label stamped on every audited write (notes / status changes /
# tasks) — shows up as `created_by` / `changed_by`. Defaults to "MCP".
# Example: "Claude (n8n)"
MCP_ACTOR=
